# Server configuration DSL: bind address, worker count, connection cap.
Tester.describe("server config") do |t: &var Tester|
  t.it("defaults to 127.0.0.1:3000") do
    var app = Rondo.new
    t.expect(app.bind_addr.clone).to_eq("127.0.0.1:3000")
  end

  t.it("port() changes only the port") do
    var app = Rondo.new
    app.port(9292)
    t.expect(app.bind_addr.clone).to_eq("127.0.0.1:9292")
  end

  t.it("host() + port() compose into the bind address") do
    var app = Rondo.new
    app.port(9292)
    app.host(&"0.0.0.0")
    t.expect(app.bind_addr.clone).to_eq("0.0.0.0:9292")
  end

  t.it("workers() sets the worker count") do
    var app = Rondo.new
    app.workers(2)
    t.expect(app.worker_count).to_eq(2)
  end

  t.it("max_connections caps acquisition, then release frees a slot") do
    var app = Rondo.new
    app.max_connections(1)
    let _ = BoolMatcher.new(app.try_acquire_connection).to_be_truthy
    let _ = BoolMatcher.new(app.try_acquire_connection).to_be_falsy
    app.release_connection
    let _ = BoolMatcher.new(app.try_acquire_connection).to_be_truthy
  end
end
